{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://questi0nm4rk.dev/tagen/tagen-get-manifest.schema.json",
  "title": "TagenGetManifest",
  "description": "Output shape of `tagen get --json`. Stable contract — breaking changes require a dedicated PR with consumer updates in lockstep.",
  "type": "object",
  "required": [
    "root",
    "modules",
    "core",
    "references",
    "filled",
    "slots",
    "subagents",
    "validators",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "root": {
      "type": "string",
      "description": "Absolute path of the marketplace dir. All other paths are relative to this."
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name", "core"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "name": { "type": "string" },
          "core": { "type": "string" }
        }
      }
    },
    "core": {
      "type": "array",
      "items": { "type": "string" }
    },
    "references": {
      "type": "array",
      "items": { "type": "string" }
    },
    "filled": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["core", "references"],
        "additionalProperties": false,
        "properties": {
          "core": { "type": "string" },
          "references": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "fillerCard", "candidates"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "fillerCard": { "type": "string" },
          "candidates": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "subagents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validators": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
