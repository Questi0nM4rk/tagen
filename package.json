{
  "name": "@questi0nm4rk/tagen",
  "version": "3.0.0",
  "description": "Harness-agnostic context graph CLI for composable brain cards",
  "keywords": [
    "agent-context",
    "context-graph",
    "harness-agnostic",
    "prompt-composition",
    "ai-workflow",
    "markdown",
    "yaml"
  ],
  "author": "Questi0nM4rk",
  "license": "MIT",
  "homepage": "https://github.com/Questi0nM4rk/tagen#readme",
  "bugs": {
    "url": "https://github.com/Questi0nM4rk/tagen/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Questi0nM4rk/tagen.git"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "tagen": "bin/tagen.js"
  },
  "exports": {
    ".": {
      "import": "./bin/tagen.js"
    },
    "./validator-runtime": {
      "types": "./src/validator-runtime.ts",
      "import": "./src/validator-runtime.ts"
    }
  },
  "files": [
    "bin/tagen.js",
    "src/validator-runtime.ts",
    "src/lib/errors.ts"
  ],
  "scripts": {
    "build": "bun build src/main.ts --compile --outfile bin/tagen",
    "build:npm": "bun build src/main.ts --target=bun --outfile bin/tagen.js && printf '#!/usr/bin/env bun\n' | cat - bin/tagen.js > /tmp/tagen-tmp-$$.js && mv /tmp/tagen-tmp-$$.js bin/tagen.js && chmod +x bin/tagen.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsgo --noEmit",
    "lint": "biome check src/ __tests__/ features/ scripts/",
    "lint:fix": "biome check --write src/ __tests__/ features/ scripts/",
    "check:doc-counts": "bun scripts/check-doc-counts.ts",
    "changelog": "git cliff -o CHANGELOG.md",
    "changelog:unreleased": "git cliff --unreleased --prepend CHANGELOG.md",
    "prepublishOnly": "bun run typecheck && bun test && bun scripts/check-doc-counts.ts && bun run build:npm"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@questi0nm4rk/feats": "^1.0.1",
    "@typescript/native-preview": "^7.0.0-dev.20260619.1",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
